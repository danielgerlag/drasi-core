          "previous_close": 140.50,
          "volume": 3000000
        }
      }
    },
    {
      "operation": "update",
      "element": {
        "type": "node",
        "id": "price_NVDA",
        "labels": ["stock_prices"],
        "properties": {
          "symbol": "NVDA",
          "price": 560.00,
          "previous_close": 515.00,
          "volume": 9000000
        }
      }
    },
    {
      "operation": "update",
      "element": {
        "type": "node",
        "id": "price_AMZN",
        "labels": ["stock_prices"],
        "properties": {
          "symbol": "AMZN",
